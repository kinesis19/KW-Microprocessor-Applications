    "# Mission 2: Control LED Brightness\n",
    "import RPi.GPIO as GPIO\n",
    "import time\n",
    "\n",
    "GPIO.setmode(GPIO.BCM)\n",
    "GPIO.setup(5, GPIO.OUT)\n",
    "pwm = GPIO.PWM(5, 100)\n",
    "duty = 50.0\n",
    "pwm.start(duty)\n",
    "\n",
    "try:\n",
    "    while(True):\n",
    "        pass\n",
    "finally:\n",
    "    print('cleaning up')\n",
    "    GPIO.cleanup()"
   ]
  }
